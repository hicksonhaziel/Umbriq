PORT=4000
HOST=0.0.0.0
DATABASE_URL="postgresql://user:password@localhost:5432/umbriq_db?schema=public"
REDIS_URL="redis://localhost:6379"
SESSION_TTL_SECONDS=28800

# No institution settlement key is required on the API server.
# Real settlement signing happens in the browser wallet.

# Optional local-only smoke test helper.
# These keys are used by the standalone smoke script, not by the API server.
UMBRA_SMOKE_NETWORK=devnet
UMBRA_SMOKE_INSTITUTION_PRIVATE_KEY_PATH=/tmp/institution.json
UMBRA_SMOKE_INSTITUTION_PRIVATE_KEY_JSON=
UMBRA_SMOKE_INSTITUTION_PRIVATE_KEY_BASE58=
UMBRA_SMOKE_MARKET_MAKER_PRIVATE_KEY_PATH=/tmp/market-maker.json
UMBRA_SMOKE_MARKET_MAKER_PRIVATE_KEY_JSON=
UMBRA_SMOKE_MARKET_MAKER_PRIVATE_KEY_BASE58=
UMBRA_SMOKE_TRANSFER_AMOUNT=1
